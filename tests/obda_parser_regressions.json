{
  "suite_name": "obda_parser_regressions",
  "suite_version": 2,
  "cases": [
    {
      "id": "deterministic_numeric_constraint_unit_parse",
      "description": "Deterministic parser 应稳定抽出锚点和显式数值约束。",
      "payload": {
        "mode": "unit",
        "template": "causal_lookup",
        "question": "13800138004是否存在满意度评分低于3的情况"
      },
      "assertions": [
        {
          "path": "parser_output.strategy",
          "equals": "DeterministicStrategy"
        },
        {
          "path": "parser_output.model_backend",
          "equals": "NoModelBackend"
        },
        {
          "path": "slots.has_anchor",
          "equals": true
        },
        {
          "path": "slots.anchors[0].value",
          "equals": "13800138004"
        },
        {
          "path": "slots.status_numeric_constraint.attribute_text",
          "equals": "满意度评分"
        },
        {
          "path": "slots.status_numeric_constraint.op",
          "equals": "lt"
        },
        {
          "path": "slots.status_numeric_constraint.value",
          "equals": 3
        }
      ]
    },
    {
      "id": "deterministic_multi_unit_utterance_parse",
      "description": "Deterministic parser 应保持多句拆分与条件依赖。",
      "payload": {
        "mode": "utterance",
        "template": "causal_lookup",
        "question": "13800138004是否存在满意度评分低于3的情况？如果有，有什么解决方案？"
      },
      "assertions": [
        {
          "path": "question_units[0].text",
          "equals": "13800138004是否存在满意度评分低于3的情况"
        },
        {
          "path": "question_units[1].text",
          "equals": "有什么解决方案"
        },
        {
          "path": "question_units[1].dependency.depends_on",
          "equals": "q1"
        },
        {
          "path": "question_units[1].dependency.condition",
          "equals": "non_empty_or_true"
        },
        {
          "path": "unit_parses[0].parser_output.strategy",
          "equals": "DeterministicStrategy"
        },
        {
          "path": "unit_parses[1].parser_output.strategy",
          "equals": "DeterministicStrategy"
        }
      ]
    },
    {
      "id": "deterministic_reference_marker_unit_parse",
      "description": "Deterministic parser 应保留结果集引用标记。",
      "payload": {
        "mode": "unit",
        "template": "causal_enumeration",
        "question": "这些客户的投诉原因分别是什么"
      },
      "assertions": [
        {
          "path": "parser_output.question_units[0].reference_markers[0]",
          "equals": "这些"
        },
        {
          "path": "question_unit.raw_text",
          "equals": "这些客户的投诉原因分别是什么"
        }
      ]
    },
    {
      "id": "deterministic_causal_surface_split_parse",
      "description": "Deterministic parser 应把口语化因果枚举稳定拆成 result/cause/action 三个 surface hints。",
      "payload": {
        "mode": "unit",
        "template": "causal_enumeration",
        "question": "有哪些客户因为5G信号差而投诉了?"
      },
      "assertions": [
        {
          "path": "parser_output.strategy",
          "equals": "DeterministicStrategy"
        },
        {
          "path": "slots.bootstrap_candidates.cause_text[0].text",
          "equals": "5G信号差"
        },
        {
          "path": "slots.bootstrap_candidates.result_hint[0].text",
          "equals": "客户"
        },
        {
          "path": "slots.bootstrap_candidates.action_text[0].text",
          "equals": "投诉"
        }
      ]
    },
    {
      "id": "anthropic_cli_backend_unavailable_preserves_multi_unit_fallback",
      "description": "Anthropic-compatible CLI backend 不可用时，应保留多句拆分并安全降回 deterministic unit bundle。",
      "payload": {
        "mode": "utterance",
        "template": "causal_lookup",
        "question": "13800138004是否存在满意度评分低于3的情况？如果有，有什么解决方案？",
        "env": {
          "OBDA_MODEL_BACKEND": "AnthropicCompatibleCliBackend",
          "OBDA_MODEL_BINARY": "__no_such_parser_backend__"
        }
      },
      "assertions": [
        {
          "path": "parser_output.strategy",
          "equals": "HybridStrategy"
        },
        {
          "path": "parser_output.model_backend",
          "equals": "AnthropicCompatibleCliBackend"
        },
        {
          "path": "parser_output.ambiguities[0].kind",
          "equals": "backend_unavailable"
        },
        {
          "path": "question_units[1].dependency.depends_on",
          "equals": "q1"
        },
        {
          "path": "unit_parses[0].parser_output.strategy",
          "equals": "DeterministicStrategy"
        },
        {
          "path": "unit_parses[0].parser_output.model_backend",
          "equals": "NoModelBackend"
        },
        {
          "path": "unit_parses[1].parser_output.strategy",
          "equals": "DeterministicStrategy"
        },
        {
          "path": "unit_parses[1].parser_output.model_backend",
          "equals": "NoModelBackend"
        }
      ]
    },
