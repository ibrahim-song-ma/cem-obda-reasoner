ex:bindAction a owl:ObjectProperty ;
    rdfs:label "本体对象关联行动"@zh ;
    rdfs:domain owl:Thing,
        prov:Entity,
        ex:Entity,
        ex:Object ;
    rdfs:range owl:Thing,
        prov:Activity,
        ex:Action ;
    rdfs:subPropertyOf ex:bindAction ;
    owl:equivalentProperty ex:bindAction ;
    owl:sameAs ex:bindAction .

