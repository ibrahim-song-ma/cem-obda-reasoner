ex:is_low_satisfaction a owl:Thing,
        prov:Activity,
        ex:Logic ;
    rdfs:label "判断是否属于低满意度"@zh ;
    rdfs:comment """@function_label: 判断是否属于低满意度
    根据预测模型预测的分数判断是否低满意度。 输入参数参数：score。 返回：bool。"""@zh ;
    owl:sameAs ex:is_low_satisfaction ;
    ex:hasParameter _:nfbbe8a9924e44c44be07f9df5571a212b6 .

