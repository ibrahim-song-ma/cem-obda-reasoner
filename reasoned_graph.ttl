ex:assign_order_to_employee a owl:Thing,
        prov:Activity,
        ex:Action,
        ex:Logic ;
    rdfs:label "分配工单"@zh ;
    rdfs:comment """@action_label: 分配工单
    分配工单给指定员工"""@zh ;
    owl:sameAs ex:assign_order_to_employee ;
    ex:hasParameter _:nfbbe8a9924e44c44be07f9df5571a212b7,
        _:nfbbe8a9924e44c44be07f9df5571a212b8 .

ex:calculate_customer_satisfaction a owl:Thing,
        prov:Activity,
        ex:Logic ;
    rdfs:label "计算客户的满意度"@zh ;
    rdfs:comment """@function_label: 计算客户的满意度
    根据客户ID与感知分析算法ID，调用指定算法计算该客户的满意度评分。入参：customer_id（str）、perception_id（str）。返回：满意度分数float。用于评估客户体验与服务质量。"""@zh ;
    owl:sameAs ex:calculate_customer_satisfaction ;
    ex:hasParameter _:nfbbe8a9924e44c44be07f9df5571a212b1,
        _:nfbbe8a9924e44c44be07f9df5571a212b2 .

ex:create_work_order a owl:Thing,
        prov:Activity,
        ex:Action,
        ex:Logic ;
    rdfs:label "创建工单"@zh ;
    rdfs:comment """@action_label: 创建工单
    创建不同类型的待指派工单（类型跟随服务类型），根据客户的反馈内容判断是哪一种类型的工单。
    同时需要根据客户反馈内容，判断工单涉及的感知维度，需要填入对应的perception_id.
     - perception_id: 'PER002' -> 网优维度，涉及网络优化方向的解决及修复
     - perception_id: 'PER003' -> 服务维度，涉及线上线下渠道对客时的问题
     - perception_id: 'PER004' -> 资费维度，涉及产品资费方向的问题
    创建工单时，如果已经有建议方案，则可以通过advice_content添加进工单中"""@zh ;
    owl:sameAs ex:create_work_order ;
    ex:hasParameter _:nfbbe8a9924e44c44be07f9df5571a212b10,
        _:nfbbe8a9924e44c44be07f9df5571a212b11,
        _:nfbbe8a9924e44c44be07f9df5571a212b12,
        _:nfbbe8a9924e44c44be07f9df5571a212b13,
        _:nfbbe8a9924e44c44be07f9df5571a212b9 .

