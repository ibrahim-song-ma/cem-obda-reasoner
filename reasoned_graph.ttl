ex:get_network_logs a owl:Thing,
        prov:Activity,
        ex:Logic ;
    rdfs:label "获取网络工作日志"@zh ;
    rdfs:comment """@function_label: 获取网络工作日志
    该函数用于获取指定无线网络的工作日志。输入参数为无线网络ID network_id（字符串），用于唯一标识目标网络。函数通过该ID查询并返回该无线网络的工作日志数据，用于光猫，宽带故障排查、运行状态分析与审计。返回值为该网络的完整或筛选后的日志信息。"""@zh ;
    owl:sameAs ex:get_network_logs ;
    ex:hasParameter _:nfbbe8a9924e44c44be07f9df5571a212b5 .

