        prov:Entity,
        ex:Entity,
        ex:Object,
        ex:perception ;
    owl:sameAs ex:perception_PER001 ;
    ex:perception_感知ID "PER001" ;
    ex:perception_感知分析算法 "综合满意度评估算法" ;
    ex:perception_感知分析算法原理描述 "基于多维度评分计算综合满意度，包括网络体验、服务体验、资费感知等维度，权重分别为0.4, 0.3, 0.3" ;
    ex:perception_感知时间 "2026-03-15T10:00:00"^^xsd:dateTime ;
    ex:perception_感知维度 "满意度" .

