  ex:hasPrimaryKey ex:perceptionevaluation_感知评估ID ;
  ex:hasTitle ex:perceptionevaluation_评估描述 ;
  rdfs:comment "感知评估"@zh .

ex:remediationstrategy a owl:Class ;
  rdfs:subClassOf ex:Object ;
  rdfs:label "修复策略"@zh ;
  rdfs:label "remediationstrategy"@en ;
  ex:hasPrimaryKey ex:remediationstrategy_修复策略ID ;
  ex:hasTitle ex:remediationstrategy_修复客户行为属性名称 ;
  rdfs:comment "修复策略，针对客户行为属性中某个指标低进行修复，其中修复策略名称对应的是客户行为的属性。"@zh .

ex:terminal a owl:Class ;
