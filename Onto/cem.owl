##################################
# 关系定义
# 必须继承ex:custom_relation
# 有正向关系就需定义一个反向关系
# IRI命名规则：ex:{domain}_{relationLabel}_{range}
# 这样可以支持多组对象对使用相同的关系标签
##################################
ex:workorder_is_linked_to_customer a owl:ObjectProperty ;
  rdfs:subPropertyOf ex:custom_relation ;
  rdfs:domain ex:workorder ;
  rdfs:range ex:customer ;
  rdfs:label "被关联"@zh ;
  ex:relationLabel "is_linked_to"@zh ;
  ex:domainAttribute ex:workorder_客户ID ;
  ex:rangeAttribute ex:customer_客户ID ;
  rdfs:comment ""@zh .

ex:customer_linkedWith_workorder a owl:ObjectProperty ;
  rdfs:subPropertyOf ex:custom_relation ;
  rdfs:domain ex:customer ;
  rdfs:range ex:workorder ;
  rdfs:label "关联"@zh ;
  ex:relationLabel "linkedWith"@zh ;
  ex:domainAttribute ex:customer_客户ID ;
  ex:rangeAttribute ex:workorder_客户ID ;
  rdfs:comment ""@zh .

