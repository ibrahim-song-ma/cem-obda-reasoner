  rdfs:label "event"@en ;
  ex:hasPrimaryKey ex:event_event_id ;
  ex:hasTitle ex:event_事件类型 ;
  rdfs:comment "系统接收各种维度的事件"@zh .

ex:packageproduct a owl:Class ;
  rdfs:subClassOf ex:Object ;
  rdfs:label "套餐产品"@zh ;
  rdfs:label "packageproduct"@en ;
  ex:hasPrimaryKey ex:packageproduct_产品ID ;
  ex:hasTitle ex:packageproduct_套餐产品名称 ;
  rdfs:comment "套餐产品"@zh .

ex:perception a owl:Class ;
  rdfs:subClassOf ex:Object ;
  rdfs:label "感知分析"@zh ;
  rdfs:label "perception"@en ;
  ex:hasPrimaryKey ex:perception_感知ID ;
  ex:hasTitle ex:perception_感知分析算法 ;
  rdfs:comment "感知"@zh .

ex:perceptionevaluation a owl:Class ;
  rdfs:subClassOf ex:Object ;
  rdfs:label "感知评估"@zh ;
