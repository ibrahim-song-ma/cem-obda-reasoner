@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ex: <http://ywyinfo.com/example-owl#> .

##################################
# 基础抽象类与通用语义（禁止变动）
##################################
ex:Entity a owl:Class ; rdfs:subClassOf prov:Entity ; rdfs:label "实体"@zh .
ex:Object a owl:Class ; rdfs:subClassOf ex:Entity ; rdfs:label "本体对象"@zh .
ex:Action a owl:Class ; rdfs:subClassOf prov:Activity ; rdfs:label "行动"@zh .
ex:Logic a owl:Class ; rdfs:subClassOf prov:Activity ; rdfs:label "决策/逻辑函数"@zh .
ex:hasPrimaryKey a owl:AnnotationProperty ; rdfs:label "主键属性"@zh ; rdfs:comment "在类级别声明该对象的主键数据属性"@zh .
ex:hasTitle a owl:AnnotationProperty ; rdfs:label "标题属性"@zh ; rdfs:comment "在类级别声明该对象的标题数据属性"@zh .
ex:bindAction a owl:ObjectProperty ; rdfs:label "本体对象关联行动"@zh ; rdfs:domain ex:Object ; rdfs:range ex:Action .
ex:bindLogic a owl:ObjectProperty ; rdfs:label "本体对象关联函数"@zh ; rdfs:domain ex:Object ; rdfs:range ex:Logic .
ex:custom_relation a owl:ObjectProperty ; rdfs:label "自定义对象与对象之间的关系"@zh .
ex:Parameter a owl:Class ; rdfs:label "函数参数"@zh .
ex:hasParameter a owl:ObjectProperty ; rdfs:label "有参数"@zh ; rdfs:domain ex:Logic ; rdfs:range ex:Parameter .
ex:paramName a owl:DatatypeProperty ; rdfs:label "参数名"@zh ; rdfs:domain ex:Parameter ; rdfs:range xsd:string .
ex:paramType a owl:DatatypeProperty ; rdfs:label "参数类型"@zh ; rdfs:domain ex:Parameter ; rdfs:range xsd:string .
ex:paramTypeNode a owl:ObjectProperty ; rdfs:label "参数类型节点"@zh ; rdfs:domain ex:Parameter .
ex:ListType a owl:Class ; rdfs:label "列表类型"@zh .
ex:DictType a owl:Class ; rdfs:label "字典类型"@zh .
ex:itemType a owl:DatatypeProperty ; rdfs:label "元素类型"@zh .
ex:keyType a owl:DatatypeProperty ; rdfs:label "键类型"@zh .
ex:valueType a owl:DatatypeProperty ; rdfs:label "值类型"@zh .
ex:isOptional a owl:DatatypeProperty ; rdfs:label "是否可选"@zh ; rdfs:domain ex:Parameter ; rdfs:range xsd:boolean .
ex:defaultValue a owl:DatatypeProperty ; rdfs:label "默认值"@zh ; rdfs:domain ex:Parameter ; rdfs:range xsd:string .
ex:ontologyName a owl:Class ; rdfs:label "本体名称"@zh .
ex:domainAttribute a owl:AnnotationProperty ; rdfs:label "域属性"@zh ; rdfs:comment "指定对象属性的域端使用哪个数据属性建立关联"@zh .
ex:rangeAttribute a owl:AnnotationProperty ; rdfs:label "值域属性"@zh ; rdfs:comment "指定对象属性的值域端使用哪个数据属性建立关联"@zh .
ex:relationLabel a owl:AnnotationProperty ; rdfs:label "关系标签"@zh ; rdfs:comment "表示关系的语义标签名称（如hasOrder、isPartOf等），用于标识关系类型"@zh .
ex:hasMiddleObject a owl:ObjectProperty ; rdfs:label "中间对象"@zh ; rdfs:comment "用来描述多对多关系的情况下，两个对象所使用到的中间对象"@zh .
##################################
# 本体名称
##################################
ex:CEM a ex:ontologyName ;
  rdfs:label "客户体验管理"@zh .

##################################
# 可用函数
##################################
ex:calculate_customer_satisfaction a ex:Logic ;
  rdfs:label "计算客户的满意度"@zh ;
  rdfs:comment """@function_label: 计算客户的满意度
    根据客户ID与感知分析算法ID，调用指定算法计算该客户的满意度评分。入参：customer_id（str）、perception_id（str）。返回：满意度分数float。用于评估客户体验与服务质量。"""@zh ;
  ex:hasParameter [ a ex:Parameter ; ex:paramName "customer_id" ; ex:paramType "xsd:string" ; ex:isOptional false ], [ a ex:Parameter ; ex:paramName "perception_id" ; ex:paramType "xsd:string" ; ex:isOptional false ] .

ex:generate_remediation_strategy a ex:Logic ;
  rdfs:label "生成修复策略"@zh ;
  rdfs:comment """@function_label: 生成修复策略
    函数“生成修复策略”用于基于客户低分行为属性列表，生成相应的修复策略。入参包括：customerbehavior_attribute_name_list（低分行为属性名列表，如[web_disp_rate,video_play_succ_rate],你可以从之前的感知分析的算法描述中获取相关信息）。输出为针对该客户与属性的修复方案。"""@zh ;
  ex:hasParameter [ a ex:Parameter ; ex:paramName "customerbehavior_attribute_name_list" ; ex:paramType "list" ; ex:isOptional false ; ex:paramTypeNode [ a ex:ListType ] ] .

ex:get_network_logs a ex:Logic ;
  rdfs:label "获取网络工作日志"@zh ;
  rdfs:comment """@function_label: 获取网络工作日志
    该函数用于获取指定无线网络的工作日志。输入参数为无线网络ID network_id（字符串），用于唯一标识目标网络。函数通过该ID查询并返回该无线网络的工作日志数据，用于光猫，宽带故障排查、运行状态分析与审计。返回值为该网络的完整或筛选后的日志信息。"""@zh ;
  ex:hasParameter [ a ex:Parameter ; ex:paramName "network_id" ; ex:paramType "xsd:string" ; ex:isOptional false ] .

ex:is_low_satisfaction a ex:Logic ;
  rdfs:label "判断是否属于低满意度"@zh ;
  rdfs:comment """@function_label: 判断是否属于低满意度
    根据预测模型预测的分数判断是否低满意度。 输入参数参数：score。 返回：bool。"""@zh ;
  ex:hasParameter [ a ex:Parameter ; ex:paramName "score" ; ex:paramType "xsd:double" ; ex:isOptional false ] .

##################################
# Action动作定义
##################################
ex:assign_order_to_employee a ex:Action ;
  rdfs:label "分配工单"@zh ;
  rdfs:comment """@action_label: 分配工单
    分配工单给指定员工"""@zh ;
  ex:hasParameter [ a ex:Parameter ; ex:paramName "workorder_id" ; ex:paramType "xsd:string" ; ex:isOptional false ] ,
                    [ a ex:Parameter ; ex:paramName "employee_id" ; ex:paramType "xsd:string" ; ex:isOptional false ] .

ex:workorder ex:bindAction ex:assign_order_to_employee .

ex:create_work_order a ex:Action ;
  rdfs:label "创建工单"@zh ;
  rdfs:comment """@action_label: 创建工单
    创建不同类型的待指派工单（类型跟随服务类型），根据客户的反馈内容判断是哪一种类型的工单。
    同时需要根据客户反馈内容，判断工单涉及的感知维度，需要填入对应的perception_id.
     - perception_id: 'PER002' -> 网优维度，涉及网络优化方向的解决及修复
     - perception_id: 'PER003' -> 服务维度，涉及线上线下渠道对客时的问题
     - perception_id: 'PER004' -> 资费维度，涉及产品资费方向的问题
    创建工单时，如果已经有建议方案，则可以通过advice_content添加进工单中"""@zh ;
  ex:hasParameter [ a ex:Parameter ; ex:paramName "service_id" ; ex:paramType "xsd:string" ; ex:isOptional false ] ,
                    [ a ex:Parameter ; ex:paramName "cust_id" ; ex:paramType "xsd:string" ; ex:isOptional false ] ,
                    [ a ex:Parameter ; ex:paramName "perception_id" ; ex:paramType "xsd:string" ; ex:isOptional false ] ,
                    [ a ex:Parameter ; ex:paramName "issue_description" ; ex:paramType "xsd:string" ; ex:isOptional false ] ,
                    [ a ex:Parameter ; ex:paramName "advice_content" ; ex:paramType "xsd:string" ; ex:isOptional true ] .

ex:workorder ex:bindAction ex:create_work_order .

##################################
# 逻辑函数关联定义 (bindLogic)
##################################
ex:remediationstrategy ex:bindLogic ex:generate_remediation_strategy .
ex:customerbehavior ex:bindLogic ex:calculate_customer_satisfaction .

##################################
# 对象定义(必须继承ex:Object)
##################################
ex:broadbandnetwork a owl:Class ;
  rdfs:subClassOf ex:Object ;
  rdfs:label "宽带网络"@zh ;
  rdfs:label "broadbandnetwork"@en ;
  ex:hasPrimaryKey ex:broadbandnetwork_网络ID ;
  ex:hasTitle ex:broadbandnetwork_光纤长度单位为公里 ;
  rdfs:comment "宽带网络"@zh .

ex:customer a owl:Class ;
  rdfs:subClassOf ex:Object ;
  rdfs:label "客户"@zh ;
  rdfs:label "customer"@en ;
  ex:hasPrimaryKey ex:customer_客户ID ;
  ex:hasTitle ex:customer_姓名 ;
  rdfs:comment "客户"@zh .

ex:customerbehavior a owl:Class ;
  rdfs:subClassOf ex:Object ;
  rdfs:label "客户行为"@zh ;
  rdfs:label "customerbehavior"@en ;
  ex:hasPrimaryKey ex:customerbehavior_客户行为ID ;
  ex:hasTitle ex:customerbehavior_客户ID ;
  rdfs:comment "客户行为(包含客户的手机号)"@zh .

ex:employee a owl:Class ;
  rdfs:subClassOf ex:Object ;
  rdfs:label "员工"@zh ;
  rdfs:label "employee"@en ;
  ex:hasPrimaryKey ex:employee_员工ID ;
  ex:hasTitle ex:employee_姓名 ;
  rdfs:comment "员工"@zh .

ex:event a owl:Class ;
